{
  "name": "inventory-management-ai-mcp",
  "description": "MCP server for inventory management ai. Features reorder point, demand forecast, sku optimizer. From MEOK AI Labs.",
  "version": "1.0.0",
  "tools": [
    {
      "name": "reorder_point",
      "description": "Calculate optimal reorder point, safety stock, and economic order quantity",
      "parameters": {
        "type": "object",
        "properties": {
          "avg_daily_demand": {
            "type": "number"
          },
          "lead_time_days": {
            "type": "integer"
          },
          "safety_stock_days": {
            "type": "integer"
          },
          "service_level": {
            "type": "number"
          },
          "demand_std_dev": {
            "type": "number"
          }
        },
        "required": [
          "avg_daily_demand"
        ]
      }
    },
    {
      "name": "demand_forecast",
      "description": "Forecast future demand from historical sales data with confidence intervals.",
      "parameters": {
        "type": "object",
        "properties": {
          "historical_data": {
            "type": "number"
          },
          "periods_ahead": {
            "type": "integer"
          },
          "method": {
            "type": "string"
          },
          "seasonality_period": {
            "type": "integer"
          }
        },
        "required": [
          "historical_data"
        ]
      }
    },
    {
      "name": "sku_optimizer",
      "description": "Classify SKUs using ABC/XYZ analysis and recommend inventory strategies.",
      "parameters": {
        "type": "object",
        "properties": {
          "skus": {
            "type": "array"
          }
        },
        "required": [
          "skus"
        ]
      }
    },
    {
      "name": "warehouse_layout",
      "description": "Plan warehouse zone layout optimized for picking efficiency.",
      "parameters": {
        "type": "object",
        "properties": {
          "zones": {
            "type": "array"
          },
          "total_sqft": {
            "type": "number"
          },
          "picking_method": {
            "type": "string"
          }
        },
        "required": [
          "zones"
        ]
      }
    },
    {
      "name": "shrinkage_detector",
      "description": "Detect inventory shrinkage by comparing expected vs actual quantities.",
      "parameters": {
        "type": "object",
        "properties": {
          "inventory_records": {
            "type": "array"
          }
        },
        "required": [
          "inventory_records"
        ]
      }
    }
  ]
}